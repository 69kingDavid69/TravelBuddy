# ─── LLM Provider (OpenAI-compatible) ────────────────────────────────────────
#
# Option A — Groq (FREE, recommended for demos)
#   Sign up at https://console.groq.com → API Keys → Create Key
#   LLM_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
# Option B — DeepSeek (paid, originally specified in architecture)
#   Sign up at https://platform.deepseek.com
#   LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#
# You can also keep the legacy DEEPSEEK_API_KEY variable for backwards compatibility.

LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Legacy DeepSeek key — used as fallback if LLM_API_KEY is not set
DEEPSEEK_API_KEY=

# ─── Web search ───────────────────────────────────────────────────────────────
# Tavily API key — used by the web_search tool.
# Free tier: 1,000 searches/month, no credit card required.
# Sign up at https://tavily.com → Dashboard → copy your API key.
# Leave empty to fall back to Wikipedia search (encyclopedic queries only).
TAVILY_API_KEY=

# ─── RAG ──────────────────────────────────────────────────────────────────────
# URL to scrape and index into ChromaDB for the rag_retriever tool
RAG_SOURCE_URL=https://en.wikivoyage.org/wiki/Medell%C3%ADn

# ─── TTS ──────────────────────────────────────────────────────────────────────
# Piper ONNX voice model filename (without extension) for each language
PIPER_VOICE_ES=es_MX-claude-high
PIPER_VOICE_EN=en_US-amy-medium

# Directory where the Piper .onnx and .onnx.json voice files are stored
PIPER_VOICES_DIR=/data/voices

# ─── Storage ──────────────────────────────────────────────────────────────────
# Directory where ChromaDB stores its vector index
CHROMA_DIR=/data/chroma

# ─── API ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173

# Number of conversation pairs (user + assistant) kept in the sliding memory window
MEMORY_WINDOW=7
